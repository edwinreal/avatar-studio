generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String?
  visualMood     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scenes        Scene[]
  avatars       Avatar[]
  voiceProfiles VoiceProfile[]
  behaviorProfiles BehaviorProfile[]
  assets        Asset[]
  jobs          Job[]
}

model Scene {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  timelineJson Json?
  camera      Json?
  lighting    Json?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets      Asset[]
  jobs        Job[]
}

model Avatar {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  rigUrl         String?
  meta           Json?
  style          Json?
  voiceProfileId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  voiceProfile   VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  assets         Asset[]
  jobs           Job[]
}

model VoiceProfile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  provider   String   @default("elevenlabs")
  voiceId    String?
  settings   Json?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  avatars    Avatar[]
}

model BehaviorProfile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  traits     Json?
  memoryRef  String?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id        String   @id @default(cuid())
  projectId String
  sceneId   String?
  avatarId  String?
  type      String
  uri       String
  meta      Json?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene     Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  avatar    Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)
}

model Job {
  id        String   @id @default(cuid())
  type      String
  status    String   @default("queued")
  payload   Json?
  result    Json?
  progress  Int?     @default(0)
  projectId String?
  sceneId   String?
  avatarId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  scene     Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  avatar    Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)
}
