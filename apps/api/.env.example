# Backend Configuration (.env.example)
# Copy this file to .env and fill in the required values

# ============ AUTHENTICATION ============
# REQUIRED: Generate a strong JWT secret (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============ DATABASE ============
# MongoDB connection URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB=synapse_studios_dev

# ============ AI SERVICES ============
# OpenAI API Key for script analysis
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============ CLOUD STORAGE ============
# Cloudinary configuration for asset management
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============ CORS CONFIGURATION ============
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============ ENVIRONMENT ============
# Set to development, staging, or production
NODE_ENV=development
